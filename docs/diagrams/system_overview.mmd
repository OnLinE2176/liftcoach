    style SUPERADMIN fill:#F8B4C8,stroke:#E091A8,stroke-width:2px,color:#1E1E3F

    style INTERNET fill:#6C5CE7,stroke:#5A4BD1,stroke-width:2px,color:#FFFFFF
    style WEBAPP fill:#6C5CE7,stroke:#5A4BD1,stroke-width:3px,color:#FFFFFF
    style MEDIAPIPE fill:#E8A87C,stroke:#D4956A,stroke-width:2px,color:#1E1E3F

    style SUPABASE fill:#6C5CE7,stroke:#5A4BD1,stroke-width:2px,color:#FFFFFF
    style R2 fill:#6C5CE7,stroke:#5A4BD1,stroke-width:2px,color:#FFFFFF
