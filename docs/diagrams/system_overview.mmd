graph TD
    USER(("👤 User"))
    ADMIN(("🔧 Admin"))
    SUPERADMIN(("🛡️ Super Admin"))

    USER --> INTERNET["🌐 Internet<br/>Web Browser"]
    ADMIN --> INTERNET
    SUPERADMIN --> INTERNET

    INTERNET --> WEBAPP["🏋️ LiftCoach AI<br/>Streamlit Web Application"]

    WEBAPP -->|"Analyzes Form"| MEDIAPIPE["🤖 MediaPipe<br/>Pose Landmarker<br/>(BlazePose)"]
    MEDIAPIPE -->|"Displays Feedback"| WEBAPP

    WEBAPP -->|"Stores Data"| BACKEND

    subgraph BACKEND["Backend Services"]
        direction LR
        SUPABASE[("Supabase<br/>PostgreSQL Database<br/>Data Storage")]
        R2["☁️ Cloudflare R2<br/>Video Upload<br/>and Storage"]
    end

    WEBAPP -->|"Video Upload"| R2

    SUPERADMIN -.->|"Retrieves Data and<br/>Generates Reports"| BACKEND

